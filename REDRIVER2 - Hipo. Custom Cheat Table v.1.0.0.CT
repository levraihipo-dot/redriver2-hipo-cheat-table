    <CheatEntry>
      <ID>1726</ID>
      <Description>"Utiliser les gâchettes L2 et R2 pour le contrôle du véhicule"</Description>
      <Options moHideChildren="1" moManualExpandCollapse="1"/>
      <Color>FF00FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{$lua}
if not L2R2VehicleControlTimer then
    L2R2VehicleControlTimer = nil
    speedAddr = nil
    currentSpeed = 0
end
{$asm}

[ENABLE]
{$lua}
-- CONFIGURATION
local maxSpeed = 10000
local LOW_SPEED_THRESHOLD = 0.3
local LOW_SPEED_MULTIPLIER = 0.4
local smoothing = 0.15

local function readR2()
    local f = io.open("r2_value.txt", "r")
    if f then
        local val = tonumber(f:read("*a")) or 0
        f:close()
        return math.max(0, math.min(255, val))
    end
    return 0
end

local function applyCurve(trigger)
    if trigger &lt; LOW_SPEED_THRESHOLD then
        local normalized = trigger / LOW_SPEED_THRESHOLD
        return (normalized * normalized) * LOW_SPEED_THRESHOLD * LOW_SPEED_MULTIPLIER
    else
        local aboveThreshold = (trigger - LOW_SPEED_THRESHOLD) / (1 - LOW_SPEED_THRESHOLD)
        local lowSpeedMax = LOW_SPEED_THRESHOLD * LOW_SPEED_MULTIPLIER
        return lowSpeedMax + (aboveThreshold * (1 - lowSpeedMax))
    end
end

-- Vérification du fichier
local testFile = io.open("r2_value.txt", "r")
if not testFile then
    showMessage("Ce Script a besoin du fichier texte et du code python pour fonctionner.\nIls doivent être dans le même dossier que la cheat table. (Fichier .CT)")
else
    testFile:close()

    -- Obtenir l'adresse
    speedAddr = getAddress("ProcessCarPad+0x40A")

    -- Réinitialisation
    currentSpeed = 0

    -- Détruire ancien timer si existe
    if L2R2VehicleControlTimer then
        L2R2VehicleControlTimer.Enabled = false
        L2R2VehicleControlTimer.destroy()
    end

    -- Création du nouveau timer
    L2R2VehicleControlTimer = createTimer(nil)
    L2R2VehicleControlTimer.Interval = 10
    L2R2VehicleControlTimer.OnTimer = function(timer)
        if not speedAddr then return end

        local raw = readR2()
        local trigger = raw / 255
        local curvedTrigger = applyCurve(trigger)
        local targetSpeed = curvedTrigger * maxSpeed

        currentSpeed = currentSpeed + (targetSpeed - currentSpeed) * smoothing
        local finalSpeed = math.max(0, math.min(maxSpeed, math.floor(currentSpeed)))

        writeBytes(speedAddr,
                   finalSpeed &amp; 0xFF,
                   (finalSpeed &gt;&gt; 8) &amp; 0xFF,
                   (finalSpeed &gt;&gt; 16) &amp; 0xFF,
                   (finalSpeed &gt;&gt; 24) &amp; 0xFF)
    end
    L2R2VehicleControlTimer.Enabled = true

    print("Acceleration progressive activee (L2/R2 Vehicle Control)")
    print("Vitesse max: " .. maxSpeed)
end
{$asm}

[DISABLE]
{$lua}
-- Arrêt du timer
if L2R2VehicleControlTimer then
    L2R2VehicleControlTimer.Enabled = false
    L2R2VehicleControlTimer.destroy()
    L2R2VehicleControlTimer = nil
    print("Timer detruit")
end

-- Reset vitesse
if speedAddr then
    writeBytes(speedAddr, 0, 0, 0, 0)
    speedAddr = nil
end

currentSpeed = 0
print("Acceleration progressive desactivee (L2/R2 Vehicle Control)")
{$asm}
</AssemblerScript>
