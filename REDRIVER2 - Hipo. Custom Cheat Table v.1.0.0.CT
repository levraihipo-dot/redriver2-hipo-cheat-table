          <Description>"Pursuer Max Power Scale Ⓗ"</Description>
          <ShowAsHex>1</ShowAsHex>
          <ShowAsSigned>0</ShowAsSigned>
          <Color>C080FF</Color>
          <VariableType>4 Bytes</VariableType>
          <Address>gCopMaxPowerScale</Address>
        </CheatEntry>
