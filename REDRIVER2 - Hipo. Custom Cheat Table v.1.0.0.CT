    <CheatEntry>
      <ID>1722</ID>
      <Description>"Extreme Fast Cop Cheats"</Description>
      <Options moHideChildren="1" moManualExpandCollapse="1"/>
      <Color>C080FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
-- ===== ADRESSES DYNAMIQUES =====
gCopDesiredSpeedScale = getAddress("gCopDesiredSpeedScale")
gCopMaxPowerScale     = getAddress("gCopMaxPowerScale")
-- ===== VALEURS =====
base_gCopDesiredSpeedScale = 0x00001000
base_gCopMaxPowerScale     = 0x00001000
new_gCopDesiredSpeedScale  = 0x00006500
new_gCopMaxPowerScale      = 0x00001999
-- ===== TIMER UNIQUE POUR CE SCRIPT =====
if ExtremeFastCopCheats_Timer then
    ExtremeFastCopCheats_Timer.Enabled = false
    ExtremeFastCopCheats_Timer.destroy()
    ExtremeFastCopCheats_Timer = nil
end
ExtremeFastCopCheats_Timer = createTimer(nil, false)
ExtremeFastCopCheats_Timer.Interval = 100  -- vérifie toutes les 0,1s
ExtremeFastCopCheats_Timer.OnTimer = function(t)
    -- Vérifie et corrige gCopDesiredSpeedScale
    local currentSpeed = readInteger(gCopDesiredSpeedScale)
    if currentSpeed ~= new_gCopDesiredSpeedScale then
        writeInteger(gCopDesiredSpeedScale, new_gCopDesiredSpeedScale)
    end
    -- Vérifie et corrige gCopMaxPowerScale
    local currentPower = readInteger(gCopMaxPowerScale)
    if currentPower ~= new_gCopMaxPowerScale then
        writeInteger(gCopMaxPowerScale, new_gCopMaxPowerScale)
    end
end
ExtremeFastCopCheats_Timer.Enabled = true
{$asm}
[DISABLE]
{$lua}
if syntaxcheck then return end
-- 🔴 STOP TOTAL DU TIMER
if ExtremeFastCopCheats_Timer then
    ExtremeFastCopCheats_Timer.Enabled = false
    ExtremeFastCopCheats_Timer.destroy()
    ExtremeFastCopCheats_Timer = nil
end
-- Remise des valeurs de base (dynamiques)
local gCopDesiredSpeedScale = getAddress("gCopDesiredSpeedScale")
local gCopMaxPowerScale = getAddress("gCopMaxPowerScale")
writeInteger(gCopDesiredSpeedScale, 0x00001000)  -- gCopDesiredSpeedScale
writeInteger(gCopMaxPowerScale, 0x00001000)  -- gCopMaxPowerScale
{$asm}
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>248</ID>
          <Description>"Pursuer Speed Scale Ⓗ"</Description>
          <ShowAsHex>1</ShowAsHex>
          <ShowAsSigned>0</ShowAsSigned>
