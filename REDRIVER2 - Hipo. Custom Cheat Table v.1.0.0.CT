REDRIVER2.StepSim+896: 83 3C B5 9C 92 85 00 FF           - cmp dword ptr [esi*4+REDRIVER2.exe+E929C],-01
REDRIVER2.StepSim+89E: 74 3E                             - je REDRIVER2.StepSim+8DE
REDRIVER2.StepSim+8A0: 56                                - push esi
REDRIVER2.StepSim+8A1: E8 EA 23 00 00                    - call REDRIVER2.SilenceThisCar
REDRIVER2.StepSim+8A6: 83 C4 04                          - add esp,04
REDRIVER2.StepSim+8A9: 84 C0                             - test al,al
REDRIVER2.StepSim+8AB: 75 31                             - jne REDRIVER2.StepSim+8DE
REDRIVER2.StepSim+8AD: 69 04 B5 9C 92 85 00 60 02 00 00  - imul eax,[esi*4+REDRIVER2.exe+E929C],00000260
// ---------- INJECTING HERE ----------
REDRIVER2.StepSim+8B8: 57                                - push edi
// ---------- DONE INJECTING  ----------
