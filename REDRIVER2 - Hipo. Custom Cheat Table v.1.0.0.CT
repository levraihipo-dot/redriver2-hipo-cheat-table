    -- Valeur aléatoire pour addr3
    writeInteger(addr3, math.random(0,1200))
    -- Prochain intervalle aléatoire entre 10 et 20 secondes
    RandomCopNumberAndSpawn_Timer.Interval = math.random(10000, 20000)
end
-- Premier intervalle aléatoire
