      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
-- ===== RESET TIMER EXISTANT =====
if myTimer then
    myTimer.Enabled = false
    myTimer.destroy()
    myTimer = nil
end
-- ===== FLAGS =====
wasMinusOne = false
-- ===== ADRESSES DYNAMIQUES =====
local player = getAddress("player")
local car_data = getAddress("car_data")
local maxCivCars = getAddress("maxCivCars")
local pedestrianFelony = getAddress("pedestrianFelony")

addr_cam      = player + 0x49
addr_exist    = player + 0x48
addr_v19fel   = getAddress("car_data+252+260*13")
addr_onfoot   = pedestrianFelony
addr_v19dmg   = getAddress("car_data+25A+260*13")
addr_traffic  = maxCivCars
addr_extra    = getAddress("car_data+14D+260*13")
-- ===== TIMER =====
myTimere = createTimer(nil, false)
myTimere.Interval = 100
myTimere.OnTimer = function(t)
    -- Vérifie que les adresses existent
    if addr_cam and addr_exist and addr_v19fel and addr_onfoot and addr_v19dmg and addr_traffic and addr_extra then
        -- Forçage continu
        pcall(function()
            writeSmallInteger(addr_onfoot, 0)
            writeInteger(addr_traffic, 18)
            writeSmallInteger(addr_v19dmg, 0)
            writeSmallInteger(addr_v19fel, 1000)
            if readBytes(addr_extra, 1, false) ~= 0 then
                writeBytes(addr_extra, 0)
            end
            -- Détection caméra
            local cam = readBytes(addr_cam, 1, false)
            if cam == 255 then
                if not wasMinusOne then
                    writeBytes(addr_exist, 19)
                    wasMinusOne = true
                end
            else
                wasMinusOne = false
            end
        end)
    end
end
myTimere.Enabled = true
{$asm}
[DISABLE]
{$lua}
if syntaxcheck then return end
-- 🔴 STOP TOTAL SANS TOUCHER MÉMOIRE
if myTimer then
    myTimere.Enabled = false
    myTimere.destroy()
    myTimere = nil
end
wasMinusOne = false
{$asm}
