      <ID>1732</ID>
      <Description>"Spawn Policier (Véhicule + Fumée + Physique)"</Description>
      <Options moHideChildren="1" moManualExpandCollapse="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
-- ===== ADRESSES DYNAMIQUES =====
wantedCar = getAddress("wantedCar")
ReplayStreams = getAddress("ReplayStreams")
ReplayStreams_plus2 = ReplayStreams + 2

-- ===== VALEURS =====
target_wantedCar = 0
target_ReplayStreams_plus2 = 0
target_car_data = 4

-- ===== TIMER UNIQUE POUR CE SCRIPT =====
if NoWantedCarCheat_Timer then
    NoWantedCarCheat_Timer.Enabled = false
    NoWantedCarCheat_Timer.destroy()
    NoWantedCarCheat_Timer = nil
end

NoWantedCarCheat_Timer = createTimer(nil, false)
NoWantedCarCheat_Timer.Interval = 100  -- vérifie toutes les 0,1s
NoWantedCarCheat_Timer.OnTimer = function(t)
    -- Vérifie et corrige wantedCar
    local currentWanted = readInteger(wantedCar)
    if currentWanted ~= target_wantedCar then
        writeInteger(wantedCar, target_wantedCar)
    end

    -- Vérifie et corrige ReplayStreams+2
    local currentReplay = readInteger(ReplayStreams_plus2)
    if currentReplay ~= target_ReplayStreams_plus2 then
        writeInteger(ReplayStreams_plus2, target_ReplayStreams_plus2)
    end

    -- Recalcule l'adresse à chaque itération pour éviter les dérives
    local car_data_base = getAddress("car_data")
    if car_data_base then
        local car_data_offset = car_data_base + 0x14C
        local currentCarData = readByte(car_data_offset)
        if currentCarData ~= target_car_data then
            writeByte(car_data_offset, target_car_data)
        end
    end
end

NoWantedCarCheat_Timer.Enabled = true
{$asm}

[DISABLE]
{$lua}
if syntaxcheck then return end
-- 🔴 STOP TOTAL DU TIMER
if NoWantedCarCheat_Timer then
    NoWantedCarCheat_Timer.Enabled = false
    NoWantedCarCheat_Timer.destroy()
    NoWantedCarCheat_Timer = nil
end
-- Plus de remise de valeurs, le timer est simplement arrêté
{$asm}
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>1291</ID>
          <Description>"All Cars Have Tire Effects and Can Lose Hubcaps"</Description>
          <Options moHideChildren="1" moActivateChildrenAsWell="1" moAllowManualCollapseAndExpand="1"/>
          <Color>C08000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
alloc(CarEffectsData,$10)
registersymbol(CarEffectsData)
{
  - 0-4: Toggles.
  - 8-B: Vehicles ID.
}

aobscanmodule(AllCarsEffects,$process,57 05 ** ** ** ** 50 E8) // should be unique
alloc(newmem,$300)

label(code)
label(return)

newmem:

code:
  //Fix sound bug, reset effects channel:
  cmp [CameraCnt],1
  ja @f
  mov [player+5C],-1
  mov [player+5C+74*1],-1
  mov [player+5C+74*2],-1
  mov [player+5C+74*3],-1
  @@:
  push eax
  push ebx //control type turn.
  push ecx //Effects slot (there are 4).
  push esi //cp.
  push edi //Count.
  mov ebx,1
  mov ecx,-1
  nextControlType:
  mov edi,-1
  nextCar:
  inc edi
  cmp edi,#20
  jae noMoreCars
  imul esi,edi,260
  add esi,car_data
  cmp [esi+14D],bl
  jne nextCar
  //Constraints:
  checkIfPlayer:
  cmp bl,1 //Player:
  jne checkIfCutscene
  cmp [esi+150],player+4A
  jne @f
  cmp byte ptr [CarEffectsData],0
  jne nextCar
  jmp addCarEffects
  @@:
  cmp [gInGameCutsceneActive],0
  jne nextCar
  cmp byte ptr [CarEffectsData+1],0
  jne nextCar
  jmp addCarEffects
  checkIfCutscene:
  cmp bl,7 //Cutscene car:
  jne checkIfAIGetaway
  cmp byte ptr [esi+15C],7 //Engine on.
  je nextCar
  jmp addCarEffects
  checkIfAIGetaway:
  cmp bl,4 //Getaway car:
  jne checkIfPursuer
  cmp byte ptr [esi+150],8 //Engine on.
  je nextCar
  jmp addCarEffects
  checkIfPursuer:
  cmp bl,3 //Pursuers:
  jne @f
  cmp byte ptr [esi+163],0 //Dead.
  jne nextCar
  addCarEffects:
  inc ecx //Inc slot number.
    movsx eax,byte ptr [esi+14F]
    mov [ecx+CarEffectsData+8],al
  push ecx
  push ecx
  push esi
  call CheckCarEffects
  push esi
  call SwirlLeaves
  add esp,4*3
  pop ecx
  cmp ecx,3
  jae noMoreSlots
  jmp nextCar
  noMoreCars:
  //Priority order:
  cmp ebx,1
  jne @f
  mov ebx,7
  cmp byte ptr [CarEffectsData+2],0
  jne @f
  jmp nextControlType
  @@:
  cmp ebx,7
  jne @f
  mov ebx,4
  cmp byte ptr [CarEffectsData+3],0
  jne @f
  jmp nextControlType
  @@:
  cmp ebx,4
  jne @f
  mov ebx,3
  cmp byte ptr [CarEffectsData+4],0
  jne @f
  jmp nextControlType
  StopInactiveSlots:
  //Stop sounds of inactive slots:
  inc ecx
  cmp ecx,3
  ja @f
  push edi
  push esi
  push ecx
  imul esi,ecx,74
  add esi,player
  movsx edi,byte ptr [esi+5C]
  push edi
  call StopChannel
  push edi
  call UnlockChannel
  add esp,4*2
  mov word ptr [esi+5C],-1
  pop ecx
  pop esi
  pop edi
  jmp @b
  @@:
  noMoreSlots:
  pop edi
  pop esi
  pop ecx
  pop ebx
  pop eax
  mov esi,#20
  jmp return+26

AllCarsEffects:
  jmp newmem
  nop
return:
registersymbol(AllCarsEffects)

aobscanmodule(AllLoseHubcaps,$process,0F BE B0 ** ** ** ** 85 F6) // should be unique
alloc(newmema,$100)

label(codea)
label(returna)

newmema:

codea:
  mov eax,[ebp+8]
  movsx esi,byte ptr [eax+CarEffectsData+8]
  jmp returna

AllLoseHubcaps:
  jmp newmema
  nop 2
returna:
registersymbol(AllLoseHubcaps)

CheckCarEffects+21:
  db EB
//Don't check control type for effects.

[DISABLE]

AllCarsEffects:
  push edi
  add eax,car_data

unregistersymbol(AllCarsEffects)
dealloc(newmem)

AllLoseHubcaps:
  movsx esi,byte ptr [eax+player+48]

unregistersymbol(AllLoseHubcaps)
dealloc(newmema)

unregistersymbol(CarEffectsData)
dealloc(CarEffectsData)

CheckCarEffects+21:
  db 74

{
// ORIGINAL CODE - INJECTION POINT: REDRIVER2.StepSim+8B8

REDRIVER2.StepSim+892: 33 FF                             - xor edi,edi
