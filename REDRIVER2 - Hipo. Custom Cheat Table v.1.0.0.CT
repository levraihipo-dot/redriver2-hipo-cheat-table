    </CheatEntry>
    <CheatEntry>
      <ID>1729</ID>
      <Description>"Difficultée Aléatoire"</Description>
      <Options moHideChildren="1" moManualExpandCollapse="1"/>
      <Color>AE00AE</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end
math.randomseed(os.time()) -- initialisation de l'aléatoire
-- ===== ADRESSES =====
local addr1 = getAddress("gCopDesiredSpeedScale")
local addr2 = getAddress("gCopMaxPowerScale")
-- ===== VALEURS CIBLES =====
local target_val1 = 4096
local target_val2 = 4096
-- ===== TIMER UNIQUE POUR CE SCRIPT =====
if RandomCopDifficulty_Timer then
    RandomCopDifficulty_Timer.Enabled = false
    RandomCopDifficulty_Timer.destroy()
    RandomCopDifficulty_Timer = nil
end
if RandomCopDifficulty_LoopTimer then
    RandomCopDifficulty_LoopTimer.Enabled = false
    RandomCopDifficulty_LoopTimer.destroy()
    RandomCopDifficulty_LoopTimer = nil
end

-- Timer principal : génère de nouvelles valeurs aléatoires
RandomCopDifficulty_Timer = createTimer(nil, false)
RandomCopDifficulty_Timer.OnTimer = function(t)
    -- Nouvelles valeurs aléatoires
    target_val1 = math.random(3000, 5000)
    target_val2 = math.random(3000, 5000)
    -- Prochain intervalle aléatoire entre 10 et 20 secondes
    RandomCopDifficulty_Timer.Interval = math.random(2000, 10000)
end

-- Timer de boucle : applique constamment les valeurs cibles
RandomCopDifficulty_LoopTimer = createTimer(nil, false)
RandomCopDifficulty_LoopTimer.Interval = 100 -- met à jour toutes les 100ms
RandomCopDifficulty_LoopTimer.OnTimer = function(t)
    writeInteger(addr1, target_val1)
    writeInteger(addr2, target_val2)
end

-- Démarrage
RandomCopDifficulty_Timer.Interval = math.random(2000, 10000)
RandomCopDifficulty_Timer.Enabled = true
RandomCopDifficulty_LoopTimer.Enabled = true
{$asm}
[DISABLE]
{$lua}
if syntaxcheck then return end
-- 🔴 STOP TOTAL DES TIMERS
if RandomCopDifficulty_Timer then
    RandomCopDifficulty_Timer.Enabled = false
    RandomCopDifficulty_Timer.destroy()
    RandomCopDifficulty_Timer = nil
end
if RandomCopDifficulty_LoopTimer then
    RandomCopDifficulty_LoopTimer.Enabled = false
    RandomCopDifficulty_LoopTimer.destroy()
    RandomCopDifficulty_LoopTimer = nil
end
-- Remise à 4096
writeInteger(getAddress("gCopDesiredSpeedScale"), 4096)
writeInteger(getAddress("gCopMaxPowerScale"), 4096)
{$asm}
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>1730</ID>
          <Description>"Pursuer Speed Scale Ⓗ"</Description>
          <ShowAsSigned>0</ShowAsSigned>
          <Color>AE00AE</Color>
          <VariableType>4 Bytes</VariableType>
