        <CheatEntry>
          <ID>722</ID>
          <Description>"Smooth Braking"</Description>
          <Options moHideChildren="1" moActivateChildrenAsWell="1" moAllowManualCollapseAndExpand="1"/>
          <Color>C08000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
alloc(WhoABS,$10)
registersymbol(WhoABS)

aobscanmodule(SmoothBraking,$process,80 BE 4C 01 00 00 00 74 1B) // should be unique
alloc(newmem,$180)

label(code)
label(return)

newmem:

code:
  cmp byte ptr [esi+14D],1
  jne NoPlayer
  test [esi+25C],30
  jne NoPlayer
  cmp byte ptr [WhoABS],0
  je @f
  cmp [esi+150],player+4A
  je DoABS
  @@:
  cmp byte ptr [WhoABS+1],0
  je NoPlayer
  cmp [esi+150],player+BE
  jne NoPlayer
  DoABS:
  cmp eax,58F495E3 //Keep it not equal.
  jmp return
  NoPlayer:
  cmp byte ptr [esi+0000014C],00
  jmp return

SmoothBraking:
  jmp newmem
  nop 2
return:
registersymbol(SmoothBraking)

[DISABLE]

SmoothBraking:
  db 80 BE 4C 01 00 00 00

unregistersymbol(SmoothBraking)
dealloc(newmem)

unregistersymbol(WhoABS)
dealloc(WhoABS)

